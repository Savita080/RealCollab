# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8004
RELOAD=true
CORS_ORIGINS=["*"]

# ── LLM Provider Options: groq, openai ────────────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# ── API Keys ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
