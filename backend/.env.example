# Server
PORT=3000

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>

# JWT
JWT_SECRET=<random-long-string>
JWT_REFRESH_SECRET=<another-random-long-string>

# Frontend URL (for CORS + invite email links)
FRONTEND_URL=http://localhost:5173

# Redis (optional — app works without it, but presence + whiteboard caching disabled)
# Use rediss:// for TLS (Upstash), redis:// for local
REDIS_URL=rediss://:<password>@<host>:<port>

# AI Service (Python FastAPI)
AI_SERVICE_URL=http://localhost:8000

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=<your-google-client-id>.apps.googleusercontent.com

# Brevo — transactional email for workspace invites (https://brevo.com)
BREVO_API_KEY=<your-brevo-api-key>
BREVO_SENDER_EMAIL=<verified-sender@yourdomain.com>

# Razorpay — use test keys for development (no KYC required)
# Get from: https://dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
